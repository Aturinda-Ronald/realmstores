            margin: 6px 0;
            padding-left: 20px;
        }
        
        .error-log p::before {
            content: '• ';
            margin-left: -15px;
            margin-right: 5px;
        }
    </style>
</head>
<body>
    <div class="container">
        <?php if (!$isComplete): ?>
            <h1>Sending Marketing Campaign</h1>
            <p class="subtitle">Please wait while we deliver your email to selected users</p>
            
            <div class="spinner-container">
                <div class="spinner"></div>
            </div>
            
            <div class="progress-container">
                <div class="progress-bar" style="width: <?php echo $progress; ?>%;"></div>
            </div>
            <div class="progress-text"><?php echo $progress; ?>%</div>
            
            <div class="stats">
                <div class="stat-box">
                    <div class="stat-label">Sent</div>
                    <div class="stat-value"><?php echo number_format($sentCount); ?></div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Total</div>
                    <div class="stat-value"><?php echo number_format($totalUsers); ?></div>
                </div>
            </div>
            
            <div class="batch-info">
                Processing batch <?php echo ceil($currentIndex / $batchSize) + 1; ?> of <?php echo ceil($totalUsers / $batchSize); ?>
            </div>
            
            <?php if (!empty($errors)): ?>
            <div class="error-log">
                <strong>Some emails encountered issues:</strong>
                <?php foreach (array_slice($errors, 0, 10) as $error): ?>
                    <p><?php echo htmlspecialchars($error); ?></p>
                <?php endforeach; ?>
            </div>
            <?php endif; ?>
            
            <script>
                // Auto-refresh to process next batch
                setTimeout(function() {
                    window.location.reload();
                }, 500);
            </script>
            
        <?php else: ?>
            <div class="complete-icon"></div>
            <h1 class="complete-title">Campaign Sent Successfully</h1>
            <p class="complete-message">
                Your marketing email has been delivered to <strong><?php echo number_format($sentCount); ?></strong> user<?php echo $sentCount > 1 ? 's' : ''; ?>
            </p>
            
            <div class="stats">
                <div class="stat-box">
                    <div class="stat-label">Total Delivered</div>
                    <div class="stat-value"><?php echo number_format($sentCount); ?></div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Success Rate</div>
                    <div class="stat-value"><?php echo round(($sentCount / $totalUsers) * 100); ?>%</div>
                </div>
            </div>
            
            <?php
            // Clear session data
            unset($_SESSION['bulk_email']);
            ?>
            
            <a href="marketing.php" class="btn-primary">Send Another Campaign</a>
            <a href="index.php" class="btn-primary btn-secondary">Back to Dashboard</a>
        <?php endif; ?>
