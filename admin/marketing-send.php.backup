<?php
session_start();
require_once '../config.php';
require_once 'includes/functions.php';
require_once '../includes/mail_functions.php';

// Ensure admin is logged in
if (!isLoggedIn()) {
    redirect(ADMIN_URL . '/login.php');
}

// Check if bulk email session exists
if (!isset($_SESSION['bulk_email'])) {
    redirect(ADMIN_URL . '/marketing.php');
}

$bulkEmail = $_SESSION['bulk_email'];
$batchSize = $bulkEmail['batch_size'];
$currentIndex = $bulkEmail['current_index'];
$userIds = $bulkEmail['user_ids'];
$totalUsers = $bulkEmail['total_users'];
$sentCount = $bulkEmail['sent_count'];

// Optimize for speed
set_time_limit(0);
ini_set('max_execution_time', 0);

// Get the next batch of user IDs
$batchUserIds = array_slice($userIds, $currentIndex, $batchSize);

// Fetch user details for this batch
if (!empty($batchUserIds)) {
    $placeholders = implode(',', array_fill(0, count($batchUserIds), '?'));
    $stmt = $pdo->prepare("SELECT email, first_name FROM users WHERE id IN ($placeholders) AND email IS NOT NULL AND email != ''");
    $stmt->execute($batchUserIds);
    $users = $stmt->fetchAll();
} else {
    $users = [];
}

$currentBatchSent = 0;
$errors = [];

// Send emails to this batch
foreach ($users as $user) {
    try {
        if (sendMarketingEmail($user['email'], $bulkEmail['subject'], $bulkEmail['message'], $bulkEmail['products'])) {
            $currentBatchSent++;
            $sentCount++;
        }
        // Minimal delay to avoid overwhelming the mail server
        usleep(10000); // 0.01 second delay between emails
    } catch (Exception $e) {
        $errors[] = "Failed to send to " . $user['email'] . ": " . $e->getMessage();
    }
}

// Update session data
$_SESSION['bulk_email']['sent_count'] = $sentCount;
$_SESSION['bulk_email']['current_index'] = $currentIndex + count($users);

$progress = round(($sentCount / $totalUsers) * 100, 1);
$isComplete = $sentCount >= $totalUsers || $currentIndex + count($users) >= $totalUsers;

?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sending Marketing Emails - Admin Panel</title>
    <link rel="icon" type="image/svg+xml" href="<?php echo BASE_URL; ?>/assets/favicon.svg">
    <style>
        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
        }
        
        body { 
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #333;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        
        .container {
            max-width: 600px;
            width: 100%;
            background: #ffffff;
            padding: 50px 40px;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            text-align: center;
        }
        
        h1 {
            color: #1a1a1a;
            margin-bottom: 15px;
            font-size: 28px;
            font-weight: 700;
            padding: 18px;
            border-radius: 8px;
            margin-top: 25px;
            max-height: 200px;
            overflow-y: auto;
        }
        
        .error-log strong {
            display: block;
            margin-bottom: 10px;
            color: #856404;
            font-size: 14px;
        }
        
        .error-log p {
            font-size: 12px;
